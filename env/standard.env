# image to run
IMAGE_NAME=opcua_server:latest

# starting ports SubBasePort needs to be PubCount away from PubBasePort
PUB_BASE_PORT=5840
SUB_BASE_PORT=4840

# config things
CONFIG_SCRIPT=scripts/generate_sample_config.py
CONFIG_DIR=configs
CONFIG_NAME=config.toml
CONFIG_DOCKER_DIR=/app/configs

# config parameters
GROUP_COUNT = 5
DATASET_COUNT = 10
FIELD_COUNT = 15
INTERVAL = 500
# parameters
SUBSCRIBE_PROTOCOL=UADP
PUBLISH_PROTOCOL = MQTT